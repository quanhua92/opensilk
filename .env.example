# --- Security Passwords ---
POSTGRES_PASSWORD=replace_this_with_a_secure_password
REDIS_PASSWORD=replace_this_with_a_secure_password

# --- Hub Settings (Rust) ---
RUST_LOG=info
PORT=8080
JWT_SECRET=replace_this_with_a_secure_random_string

# --- Database Connections ---
DATABASE_URL=postgres://opensilk:${POSTGRES_PASSWORD}@postgres:5432/opensilk
REDIS_URL=redis://default:${REDIS_PASSWORD}@redis:6379/0

# --- Worker Settings (Python) ---
HUB_URL=http://opensilk-server:8080

# --- Dashboard Settings (Vite) ---
VITE_API_URL=http://localhost:8080
